a=input("Enter password")
up=0
lw=0
sc=0
dg=0
if(len(a)>7):
    for i in a:
        if (i.isupper()):
            up=up+1 
        elif (i.islower()):
            lw=lw+1 
        elif (i.isdigit()):
            dg=dg+1
        else:
            sc=sc=1 
    if up > 0 and lw > 0 and dg > 0 and sc > 0:
        print("strong Password!")
    else:
        print("Weak Password")
else:
    print("low value password")
